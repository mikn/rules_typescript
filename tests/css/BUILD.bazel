load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//ts:defs.bzl", "css_library", "ts_compile")

# ── CSS libraries ─────────────────────────────────────────────────────────────
# Generated by Gazelle: css_library name = CSS stem (without .css extension).

css_library(
    name = "theme",
    srcs = ["theme.css"],
    visibility = ["//visibility:public"],
)

css_library(
    name = "button",
    srcs = ["button.css"],
    visibility = ["//visibility:public"],
)

# ── TypeScript compilation with a CSS dep ────────────────────────────────────

ts_compile(
    name = "button_lib",
    srcs = ["Button.tsx"],
    deps = [":button"],
)

# ── Verification test ─────────────────────────────────────────────────────────

sh_test(
    name = "css_output_test",
    size = "small",
    srcs = ["verify_css.sh"],
    data = [
        ":button",
        ":button_lib",
        ":theme",
    ],
)

    timeout = "long",
    srcs = ["test_css_assets.sh"],
    env_inherit = ["PATH", "HOME", "USER", "RULES_TYPESCRIPT_ROOT"],
    tags = [
        "exclusive",
        "local",
        "manual",
    ],
)


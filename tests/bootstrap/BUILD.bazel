# ── test_codegen ──────────────────────────────────────────────────────────────
# ts_codegen rule in isolation — no npm, no Gazelle required.
# A shell script generator reads a schema file and emits TypeScript source.
# ts_compile consumes the generated output and produces .js + .d.ts.
sh_test(
    name = "test_codegen",
    size = "large",
    timeout = "long",
    srcs = ["test_codegen.sh"],
    env_inherit = ["PATH", "HOME", "USER", "RULES_TYPESCRIPT_ROOT"],
    tags = [

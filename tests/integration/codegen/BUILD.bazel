"""Root BUILD file for the codegen integration test workspace.

Demonstrates the ts_codegen → ts_compile pipeline:
  1. sh_binary wraps the generator shell script.
  2. ts_codegen runs the generator as a Bazel action, producing a .ts file.
  3. ts_compile compiles the generated .ts file.
"""

load("@rules_shell//shell:sh_binary.bzl", "sh_binary")
load("@rules_typescript//ts:defs.bzl", "ts_codegen", "ts_compile")

# ── Generator binary ──────────────────────────────────────────────────────────
sh_binary(
    name = "generator",
    srcs = ["generate.sh"],
)

# ── Code generation action ────────────────────────────────────────────────────
# Reads schema.txt and emits generated/record.ts.
ts_codegen(
    name = "generated_record",
    srcs = ["schema.txt"],
    outs = ["generated/record.ts"],
    args = [
        "{srcs}",
        "{out}",
    ],
    generator = ":generator",
)

# ── Compile the generated TypeScript ─────────────────────────────────────────
ts_compile(
    name = "record_lib",
    srcs = [":generated_record"],
    isolated_declarations = True,
)

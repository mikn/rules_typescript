"""Bazel integration tests for rules_typescript.

These tests use rules_bazel_integration_test to run child Bazel workspaces
that simulate real user scenarios end-to-end:
  - create a project from scratch
  - run Gazelle to generate BUILD files
  - build with ts_compile / tsgo type-checking
  - run ts_test / vitest (npm test only)

Each test workspace lives in a subdirectory of this package and contains:
  - MODULE.bazel (with {RULES_TS_ROOT} placeholder substituted at runtime)
  - BUILD.bazel, .bazelrc, .bazelversion, WORKSPACE.bazel
  - TypeScript source files
  - test_runner.sh (the commands to run inside the child workspace)

The test_runner.sh scripts derive the rules_typescript source root by walking
from BIT_WORKSPACE_DIR up to the runfiles _main/ directory and resolving the
MODULE.bazel symlink to the real source checkout.

Usage (individual):
  bazel test //tests/integration:new_project_test --test_output=all
  bazel test //tests/integration:npm_deps_test --test_output=all
  bazel test //tests/integration:existing_project_test --test_output=all
  bazel test //tests/integration:css_assets_test --test_output=all
  bazel test //tests/integration:vite_bundle_test --test_output=all
  bazel test //tests/integration:dev_server_test --test_output=all
  bazel test //tests/integration:codegen_test --test_output=all
  bazel test //tests/integration:gazelle_roundtrip_test --test_output=all
  bazel test //tests/integration:lsp_test --test_output=all

Usage (suite):
  bazel test //tests/integration/... --test_output=errors
"""

load("@bazel_binaries//:defs.bzl", "bazel_binaries")
load(
    "@rules_bazel_integration_test//bazel_integration_test:defs.bzl",
    "bazel_integration_test",
    "integration_test_utils",
)
load("@rules_shell//shell:sh_binary.bzl", "sh_binary")

# ── new_project ───────────────────────────────────────────────────────────────
# Full new-project journey: write sources → gazelle → build.
# TypeScript files have explicit return types (isolatedDeclarations = true).
# No npm deps.

sh_binary(
    name = "new_project_test_runner",
    testonly = True,
    srcs = ["new_project/test_runner.sh"],
)

bazel_integration_test(
    name = "new_project_test",
    bazel_binaries = bazel_binaries,
    bazel_version = bazel_binaries.versions.current,
    # MODULE.bazel is added to data so it appears in the runfiles tree as
    # _main/MODULE.bazel — a symlink to the real source file. The test_runner.sh
    # resolves this symlink via readlink -f to find the actual checkout root.
    data = ["//:MODULE.bazel"],
    tags = integration_test_utils.DEFAULT_INTEGRATION_TEST_TAGS + ["no-sandbox"],
    test_runner = ":new_project_test_runner",
    timeout = "long",
    workspace_files = integration_test_utils.glob_workspace_files("new_project"),
    workspace_path = "new_project",
)

# ── npm_deps ──────────────────────────────────────────────────────────────────
# npm dependency resolution: zod imported and type-checked, vitest used.
# pnpm-lock.yaml is sourced from tests/npm/ at runtime by test_runner.sh
# (not included in workspace_files — the lockfile is not part of the
# static child workspace because it needs to come from the parent checkout).

sh_binary(
    name = "npm_deps_test_runner",
    testonly = True,
    srcs = ["npm_deps/test_runner.sh"],
)

bazel_integration_test(
    name = "npm_deps_test",
    bazel_binaries = bazel_binaries,
    bazel_version = bazel_binaries.versions.current,
    data = ["//:MODULE.bazel"],
    tags = integration_test_utils.DEFAULT_INTEGRATION_TEST_TAGS + ["no-sandbox"],
    test_runner = ":npm_deps_test_runner",
    timeout = "long",
    workspace_files = integration_test_utils.glob_workspace_files("npm_deps"),
    workspace_path = "npm_deps",
)


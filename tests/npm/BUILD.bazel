load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//ts:defs.bzl", "ts_compile")

# Expose the lockfile so bootstrap tests can declare it as a data dep.
exports_files(["pnpm-lock.yaml"])

ts_compile(
    name = "app",
    srcs = ["app.ts"],
    deps = ["@npm//:zod"],
)

# 13.1: pnpm workspace support — @npm//:shared is an alias generated by
# npm_translate_lock from the workspace:* entry in tests/npm/pnpm-lock.yaml:
#   shared: {specifier: workspace:*, version: link:packages/shared}
# → alias(name = "shared", actual = "@@//packages/shared:shared")
#
# This target verifies that the @npm alias resolves to the workspace package.
# type-checking is disabled because workspace package resolution via bare
# specifier names requires additional path alias configuration in production use;
# the alias target generation in @npm is the key feature being tested here.
ts_compile(
    name = "workspace_consumer",
    srcs = ["workspace_consumer.ts"],
    deps = ["@npm//:shared"],
    enable_check = False,
)

# Test that npm_bin targets are generated and executable.
# nanoid_bin is a simple bin with no npm dependencies, making it ideal for testing.
sh_test(
    name = "npm_bin_test",
    size = "small",
    srcs = ["verify_bin_scripts.sh"],
    data = ["@npm//:nanoid_bin"],
)

# Test that multi-version npm packages generate versioned Bazel labels.
# The lockfile includes @vitest/pretty-format at 3.0.9 and 3.2.4, which
# triggers the multi-version label generation path in npm_translate_lock.
# This verifies:
#   @npm//:vitest_pretty-format_3_0_9  (versioned, specific)
#   @npm//:vitest_pretty-format_3_2_4  (versioned, specific)
#   @npm//:vitest_pretty-format        (alias → highest = 3.2.4)
sh_test(
    name = "npm_multi_version_test",
    size = "small",
    srcs = ["verify_multi_version.sh"],
    data = [
        "@npm//:vitest_pretty-format_3_0_9",
        "@npm//:vitest_pretty-format_3_2_4",
        "@npm//:vitest_pretty-format",
    ],
)

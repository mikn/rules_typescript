load("@rules_shell//shell:sh_binary.bzl", "sh_binary")
load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//ts:defs.bzl", "ts_lint")

# ── Fake linter binary ─────────────────────────────────────────────────────────
# A shell script that accepts the same CLI flags as oxlint/eslint but always
# succeeds.  Used to test the ts_lint rule plumbing without requiring a real
# linter npm package.
sh_binary(
    name = "fake_linter",
    srcs = ["fake_linter.sh"],
)

# ── ts_lint target — clean sources ─────────────────────────────────────────────
# Linting clean.ts with the fake linter should succeed, producing a stamp.
ts_lint(
    name = "clean_lint",
    srcs = ["clean.ts"],
    linter_binary = ":fake_linter",
)

# Expose the _validation output group so the smoke test can assert the stamp
# file exists after a successful lint run.
filegroup(
    name = "clean_lint_stamp",
    srcs = [":clean_lint"],
    output_group = "_validation",
)

# ── Smoke test ─────────────────────────────────────────────────────────────────
sh_test(
    name = "lint_smoke_test",
    size = "small",
    srcs = ["verify_lint.sh"],
    data = [":clean_lint_stamp"],
)

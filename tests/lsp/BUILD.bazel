"""Bazel unit tests for the tsserver resolution hook.

These tests exercise the hook's worker and resolution logic directly without
starting a full tsserver process:

  :test_resolution_map — Run the worker against the current workspace,
      assert that npm packages (zod, vitest) and internal packages appear
      in the resolution map with valid .d.ts paths.

  :test_resolve_integration — Load the hook, require typescript, and verify
      that ts._bazelPatched is true and ts.resolveModuleName is the Bazel
      wrapper.  Also verifies that zod/vitest resolve to .d.ts files when npm
      packages are available, and that path-alias resolution does not throw.

  :test_tsserver_diagnostics — Gold test: use the TypeScript Language Service API
      (ts.createLanguageService) with the hook active to verify that a virtual
      file importing from "zod" produces zero "Cannot find module" errors.

Prerequisites for the npm-resolution tests to pass:
  bazel build @npm//...   (fetches npm packages into the output base)
  bazel build //...       (builds .d.ts files into bazel-bin)
"""

load("@rules_shell//shell:sh_test.bzl", "sh_test")

sh_test(
    name = "test_resolution_map",
    size = "medium",
    srcs = ["test_resolution_map.sh"],
    data = [
        # MODULE.bazel is included so the test can resolve MODULE.bazel as a
        # symlink in the runfiles tree to locate the real workspace root.
        # (The same pattern used by //tests/integration:*_test runners.)
        "//:MODULE.bazel",
        "//tools:tsserver-hook.js",
        "//tools:tsserver-hook-worker.js",
    ],
    env_inherit = ["PATH", "HOME", "USER"],
    tags = [
        # Requires network-accessible Bazel output base and npm packages.
        "requires-network",
        # The test shells out to `bazel query` which is not hermetic.
        "no-sandbox",
    ],
    timeout = "long",
)

sh_test(
    name = "test_resolve_integration",
    size = "medium",
    srcs = ["test_resolve_integration.sh"],
    data = [
        "//:MODULE.bazel",
        "//tools:tsserver-hook.js",
        "//tools:tsserver-hook-worker.js",
        ":resolve_test.mjs",
    ],
    env_inherit = ["PATH", "HOME", "USER"],
    tags = [
        # Requires the Bazel output base to locate npm .d.ts files.
        "requires-network",
        # Shells out to `bazel info output_base` (blocked by bazel test lock,
        # but the test derives output_base from TEST_SRCDIR as a fallback).
        "no-sandbox",
    ],
    timeout = "moderate",
)

sh_test(
    name = "test_tsserver_diagnostics",
    size = "medium",
    srcs = ["test_tsserver_diagnostics.sh"],
    data = [
        "//:MODULE.bazel",
        "//tools:tsserver-hook.js",
        "//tools:tsserver-hook-worker.js",
        ":tsserver_diag_test.mjs",
    ],
    env_inherit = ["PATH", "HOME", "USER"],
    tags = [
        # Requires TypeScript available via node (system package or npm-global)
        # and a Bazel output base with fetched npm packages.
        "requires-network",
        "no-sandbox",
    ],
    timeout = "moderate",
)

"""Rule that produces a pnpm-style node_modules directory tree as a Bazel action.

node_modules:
  - Takes npm package targets (ts_npm_package) as deps
  - Produces a directory tree under bazel-bin mimicking what pnpm installs
  - The tree is created by a hermetic Bazel action (not by running pnpm)
  - Used only at runtime (test execution, dev server); NOT during compilation
  - The result is fully cacheable and reproducible

Layout produced:
  <name>_node_modules/
    react/           ← files from the react npm package
    react-dom/       ← files from the react-dom npm package
    ...

The action reads a manifest of (exec_path, dest_relative_path) pairs and
copies files so that Node.js can resolve packages at runtime.

Cross-platform implementation:
  When the JS runtime toolchain is registered (which it always is when
  ts_test or ts_binary targets are present), the file-copy action runs via
  Node.js — a cross-platform JavaScript script replaces the former bash
  script.  This enables correct behaviour on Windows where bash is not
  available.

  On systems where the toolchain is not registered the action falls back to
  a POSIX bash script (Linux/macOS only).  This fallback exists only for
  standalone use of node_modules() without any test or binary rules; in
  practice the toolchain is always registered.
"""

load("//ts/private:providers.bzl", "NpmPackageInfo")
load("//ts/private:runtime.bzl", "JS_RUNTIME_TOOLCHAIN_TYPE", "get_js_runtime")

# ─── Cross-platform builder script ─────────────────────────────────────────────
#
# This JavaScript module is written by ctx.actions.write into the output tree
# and executed by the Node.js runtime from the JS runtime toolchain.
#
# Arguments:
#   argv[2] - exec-root-relative path to the manifest file (tab-separated src\tdest lines)
#             (Bazel sets the action's cwd to the exec root, so these paths resolve correctly)
#   argv[3] - exec-root-relative path to the output directory to populate
#
# The script reads every non-empty line from the manifest, creates the
# destination directory hierarchy, and copies each source file.  Node.js's
# fs module is used throughout so the script runs identically on Linux,
# macOS, and Windows.

_BUILDER_MJS_CONTENT = """\
// Cross-platform node_modules tree builder for rules_typescript.
// Generated by Bazel; DO NOT EDIT.
import { mkdirSync, copyFileSync, readFileSync } from 'node:fs';
import { dirname, join } from 'node:path';

const manifestPath = process.argv[2];
const outDir = process.argv[3];

if (!manifestPath || !outDir) {
  process.stderr.write(
    'node_modules_builder: usage: node builder.mjs <manifest> <outDir>\\n'
  );
  process.exit(1);
}

const manifest = readFileSync(manifestPath, 'utf8');

for (const line of manifest.split('\\n')) {
  if (!line.trim()) continue;
  const tabIdx = line.indexOf('\\t');
  if (tabIdx === -1) continue;
  const src = line.slice(0, tabIdx);
  const dest = line.slice(tabIdx + 1);
  const destPath = join(outDir, dest);
  mkdirSync(dirname(destPath), { recursive: true });
  copyFileSync(src, destPath);
}
"""

# ─── Shared implementation logic ───────────────────────────────────────────────

def build_node_modules_action(ctx, packages_to_link, input_file_sets, output_name = None):
    """Writes the manifest, declares the output directory, and runs the copy action.

    Chooses the copy mechanism based on toolchain availability:
      - Node.js script via ctx.actions.run when the JS runtime toolchain is present
        (cross-platform, works on Windows).
      - POSIX bash script otherwise (Linux/macOS fallback).

    Args:
        ctx: Rule context.
        packages_to_link: List of NpmPackageInfo instances to include.
        input_file_sets: List of depsets of input files (one per package).
        output_name: Optional name for the output directory. Defaults to
            ctx.label.name. Set to "node_modules" when the directory must be
            literally named "node_modules" for Node.js ESM resolution.

    Returns:
        The declared output directory File.
    """
    manifest_lines = []
    for npm_info in packages_to_link:
        pkg_name = npm_info.package_name
        pkg_root_prefix = ""
        if npm_info.package_dir:
            pkg_json_path = npm_info.package_dir.path
            slash_idx = pkg_json_path.rfind("/")
            if slash_idx != -1:
                pkg_root_prefix = pkg_json_path[:slash_idx + 1]

        pkg_files = npm_info.all_files.to_list()
        for f in pkg_files:
            exec_path = f.path
            if pkg_root_prefix and exec_path.startswith(pkg_root_prefix):
                rel = exec_path[len(pkg_root_prefix):]
            else:
                rel = f.basename
            dest = "{}/{}".format(pkg_name, rel)
            manifest_lines.append("{}\t{}".format(exec_path, dest))

    # Write the manifest.
    manifest = ctx.actions.declare_file(
        "{}__manifest.txt".format(ctx.label.name),
    )
    ctx.actions.write(
        output = manifest,
        content = "\n".join(manifest_lines) + "\n",
    )

    # Declare the output directory tree.
    # The directory is named as ctx.label.name so that Node.js's module
    # resolution (both CJS and ESM) can find packages inside it by walking
    # up the directory tree.  When the target is named 'node_modules', this
    # creates the artifact at bazel-bin/<pkg>/node_modules/ (matching the
    # standard layout).
    dir_name = output_name if output_name else ctx.label.name
    out_dir = ctx.actions.declare_directory(dir_name)

    # ── Choose the copy mechanism ──────────────────────────────────────────────
    js_runtime = get_js_runtime(ctx)

    if js_runtime:
        # Node.js path: cross-platform, works on Windows.
        # Write the builder .mjs script as an output file so it is available
        # on the exec host during the action.
        builder = ctx.actions.declare_file(
            "{}__builder.mjs".format(ctx.label.name),
        )
        ctx.actions.write(
            output = builder,
            content = _BUILDER_MJS_CONTENT,
        )

        ctx.actions.run(
            inputs = depset(
                [manifest, builder],
                transitive = input_file_sets,
            ),
            outputs = [out_dir],
            executable = js_runtime.runtime_binary,
            arguments = js_runtime.args_prefix + [
                builder.path,
                manifest.path,
                out_dir.path,
            ],
            mnemonic = "NodeModulesTree",
            progress_message = "Building node_modules tree for %{label}",
        )
    else:
        # POSIX bash fallback for environments where the JS runtime toolchain
        # is not registered.  This path works on Linux and macOS only.
        # Build the shell script content using string concatenation (no heredoc
        # in Starlark, and triple-quoted strings may have quoting issues with
        # paths).
        script_body = (
            "#!/usr/bin/env bash\n" +
            "set -euo pipefail\n" +
            "\n" +
            'OUT_DIR="' + out_dir.path + '"\n' +
            'MANIFEST="' + manifest.path + '"\n' +
            "\n" +
            "mkdir -p \"$OUT_DIR\"\n" +
            "\n" +
            "while IFS=$'\\t' read -r src dest; do\n" +
            "  [ -z \"$src\" ] && continue\n" +
            "  dest_path=\"$OUT_DIR/$dest\"\n" +
            "  dest_dir_path=\"$(dirname \"$dest_path\")\"\n" +
            "  mkdir -p \"$dest_dir_path\"\n" +
            # Copy files instead of symlinking.  Symlinks inside a TreeArtifact
            # point at exec-root paths that are only valid during the build action;
            # they become dangling at test runtime when the runfiles tree is used.
            "  cp \"$src\" \"$dest_path\"\n" +
            "done < \"$MANIFEST\"\n"
        )

        script = ctx.actions.declare_file(
            "{}__builder.sh".format(ctx.label.name),
        )
        ctx.actions.write(
            output = script,
            content = script_body,
            is_executable = True,
        )

        ctx.actions.run(
            inputs = depset(
                [manifest, script],
                transitive = input_file_sets,
            ),
            outputs = [out_dir],
            executable = script,
            mnemonic = "NodeModulesTree",
            progress_message = "Building node_modules tree for %{label}",
        )

    return out_dir

# ─── Rule implementation ───────────────────────────────────────────────────────

def _node_modules_impl(ctx):
    # Collect the full transitive closure of npm packages.
    # NpmPackageInfo.transitive_deps is a depset containing all transitive
    # NpmPackageInfo instances.  We call to_list() once here (at analysis
    # time this is unavoidable since we need to build the manifest) and
    # deduplicate by package_name@version to avoid writing duplicate entries.
    seen = {}
    packages_to_link = []

    for dep in ctx.attr.deps:
        if NpmPackageInfo not in dep:
            fail(
                "node_modules: dep '{}' does not provide NpmPackageInfo.\n".format(dep.label) +
                "The deps attr must contain ts_npm_package targets from the @npm repository.\n" +
                "Did you mean: @npm//:{label_name}?\n".format(label_name = str(dep.label).split(":")[1] if ":" in str(dep.label) else str(dep.label)) +
                "Example: deps = [\"@npm//:react\", \"@npm//:vitest\"]",
            )
        npm_info = dep[NpmPackageInfo]
        # Include the direct dep itself.
        key = "{}@{}".format(npm_info.package_name, npm_info.package_version)
        if key not in seen:
            seen[key] = True
            packages_to_link.append(npm_info)
        # Include all transitive deps.
        for dep_info in npm_info.transitive_deps.to_list():
            dep_key = "{}@{}".format(dep_info.package_name, dep_info.package_version)
            if dep_key not in seen:
                seen[dep_key] = True
                packages_to_link.append(dep_info)

    # Collect input file depsets.
    input_file_sets = [npm_info.all_files for npm_info in packages_to_link]

    # Use the target name as the output directory name. This allows multiple
    # node_modules() targets in the same package (e.g. one named "node_modules"
    # for test/server use, one named "vite_deps" for a bundler). The vite_bundler
    # rule creates a "node_modules" symlink at runtime when the name differs.
    out_dir = build_node_modules_action(ctx, packages_to_link, input_file_sets, output_name = ctx.label.name)

    return [
        DefaultInfo(
            files = depset([out_dir]),
            runfiles = ctx.runfiles(files = [out_dir]),
        ),
    ]

# ─── Rule declaration ──────────────────────────────────────────────────────────

node_modules = rule(
    implementation = _node_modules_impl,
    attrs = {
        "deps": attr.label_list(
            doc = "ts_npm_package targets whose runtime files populate the node_modules tree.",
            providers = [NpmPackageInfo],
            mandatory = True,
        ),
    },
    toolchains = [
        config_common.toolchain_type(JS_RUNTIME_TOOLCHAIN_TYPE, mandatory = False),
    ],
    doc = """Produces a pnpm-style node_modules directory tree as a Bazel action output.

The generated tree is fully hermetic and cacheable.  It is intended for
runtime use (test execution, dev server), not for compilation (which relies
on the .d.ts outputs from ts_npm_package deps).

When the JS runtime toolchain is registered, the copy action runs via
Node.js and works on all platforms including Windows.  If the toolchain is
not registered, a POSIX bash script is used as a fallback (Linux/macOS only).

Example:
    node_modules(
        name = "node_modules",
        deps = [
            "@npm//react",
            "@npm//react-dom",
            "@npm//vitest",
        ],
    )

    ts_test(
        name = "app_test",
        srcs = ["app.test.tsx"],
        deps = [":app"],
        node_modules = ":node_modules",
    )
""",
)
